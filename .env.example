# trade_council .env
#
# Step 1: Copy this file to .env (NOT .env.example) and fill in the values below.
# Step 2: Confirm .env is gitignored (it is by default).
#
# Anthropic API key — used by mode: api specialists/moderator and the
# plan_generator agent. Get one at console.anthropic.com -> API Keys.
# Leave as-is if running entirely on Claude Code subscription auth.
ANTHROPIC_API_KEY=sk-ant-PASTE_YOUR_KEY_HERE

# Finnhub API key — used by the paper_trader's economic-calendar feed.
# Free tier (60 calls/min) is plenty. Sign up at https://finnhub.io.
# Without this, event_gates fail open and resolve_next_review falls back
# to relative-time defaults — both fixable but loud in show_trades.py.
FINNHUB_API_KEY=PASTE_YOUR_FINNHUB_KEY_HERE
